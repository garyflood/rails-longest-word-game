<% @letters.each do |l| %>
  <div><%= l %></div>
<% end %>

<form style="padding-left: 20px" action="score" method="post" data-turbo="false">
  <label for="game">What is the longest word you can find?</label>
  <input type="text" id="game" name="score">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <input type="submit" value="Play">
</form>
